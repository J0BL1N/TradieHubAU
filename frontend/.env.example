# TradieHubAU Frontend Environment Configuration
# Copy this file to .env.local and fill in values for the intended Supabase project.
# The app fails closed when either required value is missing.

# Public Supabase project configuration (never use a service-role key here)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
